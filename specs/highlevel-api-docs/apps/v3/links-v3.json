    }
  ],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "name": "Authorization",
        "in": "header",
        "description": "Use the Access Token generated with user type as Sub-Account (OR) Private Integration Token of Sub-Account.",
        "type": "http"
      },
      "Location-Access": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "name": "Authorization",
        "in": "header",
        "description": "Use the Access Token generated with user type as Sub-Account (OR) Private Integration Token of Sub-Account.",
        "type": "http"
      },
      "Location-Access-Only": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "name": "Authorization",
        "in": "header",
        "description": "Use the Access Token generated with user type as Sub-Account.",
        "type": "http"
      },
      "Agency-Access": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "name": "Authorization",
        "in": "header",
        "description": "Use the Access Token generated with user type as Agency (OR) Private Integration Token of Agency.",
        "type": "http"
      }
    },
    "schemas": {
      "LinkSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier of the trigger link",
            "example": "n4AriwEnFrGh3tu08W0U"
          },
          "name": {
            "type": "string",
            "description": "Display name of the trigger link",
            "example": "first tag"
          },
          "redirectTo": {
            "type": "string",
            "description": "URL or variable to redirect to when the trigger link is clicked",
            "example": "https://www.google.com/"
          },
          "fieldKey": {
            "type": "string",
            "description": "Template variable key used to reference this trigger link",
            "example": "{{trigger_link.n4AriwEnFrGh3tu08W0U}}"
          },
          "locationId": {
            "type": "string",
            "description": "Location ID this trigger link belongs to",
            "example": "ve9EPM428h8vShlRW1KT"
          }
        }
      },
      "GetLinksSuccessfulResponseDto": {
        "type": "object",
        "properties": {
          "links": {
            "type": "array",
            "description": "List of trigger links",
            "example": [
              {
                "id": "n4AriwEnFrGh3tu08W0U",
                "name": "first tag",
                "redirectTo": "https://www.google.com/",
                "fieldKey": "{{trigger_link.n4AriwEnFrGh3tu08W0U}}",
                "locationId": "ve9EPM428h8vShlRW1KT"
              }
            ],
            "items": {
              "$ref": "#/components/schemas/LinkSchema"
            }
          }
        }
      },
      "LinksDto": {
        "type": "object",
        "properties": {
          "locationId": {
            "type": "string",
            "description": "Location ID of the business profile",
            "example": "ve9EPM428h8vShlRW1KT"
          },
          "name": {
            "type": "string",
            "description": "Display name of the trigger link",
            "example": "first tag"
          },
          "redirectTo": {
            "type": "string",
            "description": "URL or variable to redirect to when the trigger link is clicked",
            "example": "https://www.google.com/"
          }
        },
        "required": [
          "locationId",
          "name",
          "redirectTo"
        ]
      },
      "GetLinkSuccessfulResponseDto": {
        "type": "object",
        "properties": {
          "link": {
            "description": "The trigger link object",
            "example": {
              "id": "n4AriwEnFrGh3tu08W0U",
              "name": "first tag",
              "redirectTo": "https://www.google.com/",
              "fieldKey": "{{trigger_link.n4AriwEnFrGh3tu08W0U}}",
              "locationId": "ve9EPM428h8vShlRW1KT"
            },
            "allOf": [
              {
                "$ref": "#/components/schemas/LinkSchema"
              }
            ]
          }
        }
      },
      "LinkUpdateDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Display name of the trigger link",
            "example": "first tag"
          },
          "redirectTo": {
            "type": "string",
            "description": "URL or variable to redirect to when the trigger link is clicked",
            "example": "https://www.google.com/"
          }
        },
        "required": [
          "name",
          "redirectTo"
        ]
      },
      "DeleteLinksSuccessfulResponseDto": {
        "type": "object",
        "properties": {
          "succeded": {
            "type": "boolean",
            "description": "Indicates whether the link was successfully deleted (legacy field, misspelled). Use `succeeded` with x-api-version: v3.",
            "example": true,
            "deprecated": true
          },
          "succeeded": {
            "type": "boolean",
            "description": "Indicates whether the link was successfully deleted.",
            "example": true
          }
        }
      }
    }
  },
