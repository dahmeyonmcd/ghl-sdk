# --- Private Integration Token (internal tools / single agency or location) ---
GHL_PIT=

# --- OAuth marketplace app (agency or sub-account install) ---
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
GHL_REDIRECT_URI=https://myapp.com/oauth/callback/gohighlevel

# companyId of the agency this app is installed for (once known, e.g. after the first OAuth callback)
GHL_COMPANY_ID=

# appId as registered on the GHL marketplace — required for oauth.getInstalledLocations / AgencyClient
GHL_APP_ID=

# A location to target in the example scripts
GHL_LOCATION_ID=
