{
  "name": "@dahmeyonmcd/ghl-sdk",
  "version": "0.1.0",
  "description": "Enterprise-grade Node.js SDK for the GoHighLevel API v2 with agency OAuth, multi-location token management, webhooks, and HTTP resilience.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./webhooks/express": {
      "types": "./dist/webhooks/express.d.ts",
      "import": "./dist/webhooks/express.js",
      "require": "./dist/webhooks/express.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests scripts --ext .ts",
    "typecheck": "tsc --noEmit",
    "sync:specs": "git submodule update --remote --merge specs/highlevel-api-docs",
    "generate": "tsx scripts/generate-resources.ts",
    "validate:coverage": "tsx scripts/validate-coverage.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "gohighlevel",
    "ghl",
    "sdk",
    "api",
    "typescript",
    "oauth",
    "agency"
  ],
  "license": "MIT",
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@hey-api/openapi-ts": "^0.64.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^8.57.0",
    "msw": "^2.6.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "express": ">=4"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  }
}
